{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node *)",
      "Bash(node smoke-test.mjs)",
      "Bash(node --check *)",
      "Bash(node -e *)",
      "Bash(npx playwright *)",
      "Bash(npx -y playwright *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(npm root *)",
      "Bash(npm ls *)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm start*)"
    ]
  },
  "sandbox": {
    "network": {
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.coreservices.launchservicesd",
        "com.apple.cfprefsd.daemon",
        "com.apple.system.opendirectoryd.libinfo",
        "com.apple.coremedia.*",
        "com.apple.audio.*",
        "com.apple.windowserver.*"
      ]
    }
  }
}
